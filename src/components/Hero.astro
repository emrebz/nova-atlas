---
import { Image } from "astro:assets";
import { site, waUrl } from "../config/site";
import { useTranslations, asLocale } from "../i18n/utils";
import Icon from "./Icon.astro";
import novaAtlasLogo from "../../docs/logo/nova-atlas-no-bg.png";
import novaAtlasDarkLogo from "../../docs/logo/nova-atlas-dark-mode.png";

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

{/*
  Hero visual = a pure CSS/SVG "star-sky → horizon" composition (no image →
  instant LCP, zero CLS). To swap in a real photograph later, see
  "Swapping the hero visual" in README.md — add the <img> right below the
  decorative layer with class="absolute inset-0 h-full w-full object-cover"
  fetchpriority="high" plus a dark overlay, and keep the text as-is.
*/}
<section
  id={t.nav.home.anchor}
  class="hero relative isolate overflow-hidden bg-primary-deep text-white"
>
  <!-- Decorative star field + nova glow -->
  <div class="hero-glow pointer-events-none absolute inset-0" aria-hidden="true">
  </div>
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g fill="#ffffff" class="twinkle-a">
      <circle cx="120" cy="140" r="1.6" opacity="0.55"></circle>
      <circle cx="520" cy="110" r="1.4" opacity="0.5"></circle>
      <circle cx="930" cy="90" r="1.7" opacity="0.55"></circle>
      <circle cx="1280" cy="150" r="1.5" opacity="0.5"></circle>
      <circle cx="220" cy="420" r="1.2" opacity="0.3"></circle>
      <circle cx="640" cy="360" r="1.1" opacity="0.28"></circle>
    </g>
    <g fill="#ffffff" class="twinkle-b">
      <circle cx="310" cy="260" r="1.1" opacity="0.35"></circle>
      <circle cx="760" cy="220" r="1.1" opacity="0.3"></circle>
      <circle cx="1120" cy="300" r="1.2" opacity="0.4"></circle>
      <circle cx="1390" cy="330" r="1.1" opacity="0.35"></circle>
      <circle cx="1010" cy="430" r="1.3" opacity="0.35"></circle>
    </g>
    <!-- Nova star, echoing the logo mark (outer g positions, inner g animates) -->
    <g transform="translate(1150 170)">
      <g fill="var(--brand-accent)" class="nova-star">
        <path
          d="M0 -46L10 -10L46 0L10 10L0 46L-10 10L-46 0L-10 -10Z"
          opacity="0.9"></path>
        <circle r="60" fill="url(#nova-halo)"></circle>
      </g>
    </g>
    <!-- Faint atlas meridians -->
    <g
      fill="none"
      stroke="#ffffff"
      stroke-opacity="0.07"
      stroke-width="1.2"
    >
      <path d="M-100 780 Q720 520 1540 780"></path>
      <path d="M-100 840 Q720 600 1540 840"></path>
    </g>
    <defs>
      <radialGradient id="nova-halo">
        <stop offset="0%" stop-color="var(--brand-accent)" stop-opacity="0.35"
        ></stop>
        <stop offset="100%" stop-color="var(--brand-accent)" stop-opacity="0"
        ></stop>
      </radialGradient>
    </defs>
  </svg>

  <!-- Content + brand panel -->
  <div
    class="container-site relative grid min-h-[92svh] items-center gap-12 pt-[calc(var(--header-h)+3rem)] pb-28 lg:grid-cols-[minmax(0,1.14fr)_minmax(310px,0.86fr)] lg:gap-14 lg:pt-[calc(var(--header-h)+2rem)] lg:pb-28"
  >
    <div class="max-w-3xl">
      <p
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-[0.8rem] font-semibold tracking-[0.18em] text-accent-soft uppercase"
      >
        <Icon name="star4" class="h-3.5 w-3.5" />
        {site.location}
      </p>

      <h1
        aria-label={t.hero.h1}
        class="font-display flex flex-col items-start font-bold tracking-[-0.025em]"
      >
        <span
          aria-hidden="true"
          class="hero-brand text-[clamp(3.25rem,8vw,6rem)] leading-[0.88]"
        >
          {t.hero.brand}
        </span>
        <span aria-hidden="true" class="mt-4 flex items-center gap-3">
          <span class="h-px w-20 bg-gradient-to-r from-accent-soft to-accent/20"></span>
          <Icon name="star4" class="h-3.5 w-3.5 text-accent-soft" />
          <span class="h-px w-8 bg-gradient-to-r from-accent/60 to-transparent"></span>
        </span>
        <span
          aria-hidden="true"
          class="mt-4 max-w-2xl text-[clamp(1.7rem,4vw,3.25rem)] leading-[1.08] text-white"
        >
          {t.hero.descriptor}
        </span>
      </h1>

      {/* Compact brand seal — centered under the headline on mobile/tablet;
          desktop shows the large plaque on the right. */}
      <figure class="hero-plaque-mobile mx-auto mt-8 w-fit rounded-2xl p-3.5 lg:hidden">
        <Image
          src={novaAtlasLogo}
          alt=""
          widths={[240, 360]}
          sizes="176px"
          loading="eager"
          class="theme-logo-light h-auto w-44"
        />
        <Image
          src={novaAtlasDarkLogo}
          alt=""
          widths={[320, 480, 640]}
          sizes="min(19rem, calc(100vw - 4rem))"
          loading="eager"
          class="theme-logo-dark h-auto w-[19rem] max-w-full rounded-xl"
        />
      </figure>

      <p class="mt-8 max-w-2xl text-xl leading-relaxed font-medium text-white/90">
        {t.hero.sub}
      </p>

      <p class="mt-4 max-w-2xl leading-relaxed text-white/70">
        {t.hero.lead}
      </p>

      <div class="mt-10">
        <a
          href={waUrl(locale)}
          target="_blank"
          rel="noopener"
          class="inline-flex min-h-14 items-center gap-3 rounded-full bg-wa-strong px-8 py-4 text-lg font-semibold text-white shadow-[0_12px_32px_rgb(21_128_61/0.35)] transition-transform duration-200 hover:scale-[1.03] hover:bg-wa-deep active:scale-[0.99]"
        >
          <Icon name="whatsapp" class="h-6 w-6" />
          {t.hero.cta}
        </a>
      </div>
    </div>

    <!-- Theme-aware brand seal: cream in light mode, midnight in dark mode. -->
    <div
      class="relative hidden items-center justify-center lg:flex"
      aria-hidden="true"
    >
      <!-- Soft gold halo integrates the plaque into the sky -->
      <div
        class="pointer-events-none absolute -inset-4 rounded-[2.75rem] bg-accent/20 blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-10 top-6 bottom-10 rounded-full bg-white/10 blur-2xl"
      >
      </div>

      <figure class="hero-plaque relative w-full max-w-[30rem]">
        <div class="relative overflow-hidden rounded-[1.9rem] p-10 xl:p-12">
          <!-- Warm corner sheen -->
          <div
            class="pointer-events-none absolute inset-0"
            style="background: radial-gradient(460px 300px at 80% -8%, rgb(195 154 62 / 0.16), transparent 70%);"
          >
          </div>

          <Image
            src={novaAtlasLogo}
            alt=""
            widths={[480, 677]}
            sizes="(min-width: 1280px) 30rem, 40vw"
            loading="lazy"
            decoding="async"
            class="theme-logo-light relative mx-auto h-auto w-full"
          />
          <Image
            src={novaAtlasDarkLogo}
            alt=""
            widths={[480, 720, 960]}
            sizes="(min-width: 1280px) 30rem, 40vw"
            loading="lazy"
            decoding="async"
            class="theme-logo-dark relative mx-auto h-auto w-full rounded-2xl"
          />

          <!-- Gold flourish echoing the logo's nova star -->
          <div
            class="hero-plaque-flourish relative mx-auto mt-6 flex items-center justify-center gap-3"
          >
            <span
              class="h-px w-16 bg-gradient-to-r from-transparent to-[#c39a3e]/70"
            ></span>
            <Icon name="star4" class="h-3 w-3 text-[#c39a3e]" />
            <span
              class="h-px w-16 bg-gradient-to-l from-transparent to-[#c39a3e]/70"
            ></span>
          </div>
        </div>
      </figure>
    </div>
  </div>

  <!-- Horizon arc into the next section -->
  <svg
    class="absolute right-0 bottom-0 left-0 h-[70px] w-full sm:h-[90px]"
    viewBox="0 0 1440 100"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      d="M0 100 L0 88 Q720 -20 1440 88 L1440 100 Z"
      fill="var(--surface)"></path>
    <path
      d="M0 88 Q720 -20 1440 88"
      fill="none"
      stroke="var(--brand-accent)"
      stroke-opacity="0.55"
      stroke-width="1.5"></path>
  </svg>
</section>

<style>
  .hero {
    background: linear-gradient(
      180deg,
      var(--brand-primary-deep) 0%,
      var(--brand-primary) 58%,
      #20305c 100%
    );
  }

  /* Gentle sky life: twinkling stars + a slowly breathing nova.
     The global prefers-reduced-motion rule in global.css disables these. */
  .twinkle-a {
    animation: twinkle 7s ease-in-out infinite alternate;
  }

  .twinkle-b {
    animation: twinkle 9s ease-in-out 2.5s infinite alternate-reverse;
  }

  @keyframes twinkle {
    from {
      opacity: 1;
    }
    to {
      opacity: 0.35;
    }
  }

  .nova-star {
    transform-box: fill-box;
    transform-origin: center;
    animation: nova-breathe 9s ease-in-out infinite;
  }

  @keyframes nova-breathe {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-9px) scale(1.06);
    }
  }

  /* The single brand gradient token, used as a soft atmospheric wash */
  .hero-glow {
    background:
      radial-gradient(
        640px 420px at 78% 16%,
        rgb(195 154 62 / 0.16),
        transparent 65%
      ),
      radial-gradient(
        900px 500px at 15% 110%,
        rgb(42 55 96 / 0.55),
        transparent 70%
      );
  }

  .hero-brand {
    color: var(--brand-accent-soft);
    background: linear-gradient(105deg, #c39a3e 0%, #f4dda4 48%, #c39a3e 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 12px 36px rgb(195 154 62 / 0.16);
  }

  @media (forced-colors: active) {
    .hero-brand {
      background: none;
      -webkit-text-fill-color: currentColor;
      text-shadow: none;
    }
  }

  /* Premium "brand seal": warm cream face, gold outer + white inner hairline
     (a certificate-style double frame), and a soft float above the hero. */
  .hero-plaque > div {
    background: linear-gradient(158deg, #ffffff 0%, #f4f0e8 100%);
    border: 1px solid rgb(195 154 62 / 0.4);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.85),
      inset 0 0 0 1px rgb(255 255 255 / 0.55),
      0 26px 60px -22px rgb(2 7 20 / 0.6),
      0 10px 24px -14px rgb(2 7 20 / 0.45);
  }

  .hero-plaque {
    animation: plaque-float 7s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes plaque-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  /* Compact mobile seal — same cream face + gold hairline, calmer shadow. */
  .hero-plaque-mobile {
    background: linear-gradient(158deg, #ffffff 0%, #f4f0e8 100%);
    border: 1px solid rgb(195 154 62 / 0.4);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.85),
      0 14px 30px -14px rgb(2 7 20 / 0.5);
  }

  .theme-logo-dark {
    display: none;
  }

  :global(html[data-theme="dark"]) .theme-logo-light {
    display: none;
  }

  :global(html[data-theme="dark"]) .theme-logo-dark {
    display: block;
  }

  /* The dark-mode artwork already contains its own lower divider. */
  :global(html[data-theme="dark"]) .hero-plaque-flourish {
    display: none;
  }

  :global(html[data-theme="dark"]) .hero-plaque > div {
    padding: 0.75rem;
    background: linear-gradient(145deg, #111c36 0%, #070d1a 100%);
    border-color: rgb(227 200 138 / 0.42);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      inset 0 0 0 1px rgb(195 154 62 / 0.08),
      0 28px 70px -24px rgb(0 0 0 / 0.78),
      0 0 46px rgb(195 154 62 / 0.08);
  }

  :global(html[data-theme="dark"]) .hero-plaque-mobile {
    padding: 0.5rem;
    background: linear-gradient(145deg, #111c36 0%, #070d1a 100%);
    border-color: rgb(227 200 138 / 0.42);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.08),
      0 18px 38px -16px rgb(0 0 0 / 0.72),
      0 0 30px rgb(195 154 62 / 0.08);
  }
</style>
