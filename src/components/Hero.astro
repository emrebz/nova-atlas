---
import { site, waUrl } from "../config/site";
import { useTranslations, asLocale } from "../i18n/utils";
import Icon from "./Icon.astro";

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

{/*
  Hero visual = a pure CSS/SVG "star-sky → horizon" composition (no image →
  instant LCP, zero CLS). To swap in a real photograph later, see
  "Swapping the hero visual" in README.md — add the <img> right below the
  decorative layer with class="absolute inset-0 h-full w-full object-cover"
  fetchpriority="high" plus a dark overlay, and keep the text as-is.
*/}
<section
  id={t.nav.home.anchor}
  class="hero relative isolate overflow-hidden bg-primary-deep text-white"
>
  <!-- Decorative star field + nova glow -->
  <div class="hero-glow pointer-events-none absolute inset-0" aria-hidden="true">
  </div>
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    aria-hidden="true"
  >
    <g fill="#ffffff" class="twinkle-a">
      <circle cx="120" cy="140" r="1.6" opacity="0.55"></circle>
      <circle cx="520" cy="110" r="1.4" opacity="0.5"></circle>
      <circle cx="930" cy="90" r="1.7" opacity="0.55"></circle>
      <circle cx="1280" cy="150" r="1.5" opacity="0.5"></circle>
      <circle cx="220" cy="420" r="1.2" opacity="0.3"></circle>
      <circle cx="640" cy="360" r="1.1" opacity="0.28"></circle>
    </g>
    <g fill="#ffffff" class="twinkle-b">
      <circle cx="310" cy="260" r="1.1" opacity="0.35"></circle>
      <circle cx="760" cy="220" r="1.1" opacity="0.3"></circle>
      <circle cx="1120" cy="300" r="1.2" opacity="0.4"></circle>
      <circle cx="1390" cy="330" r="1.1" opacity="0.35"></circle>
      <circle cx="1010" cy="430" r="1.3" opacity="0.35"></circle>
    </g>
    <!-- Nova star, echoing the logo mark (outer g positions, inner g animates) -->
    <g transform="translate(1150 170)">
      <g fill="var(--brand-accent)" class="nova-star">
        <path
          d="M0 -46L10 -10L46 0L10 10L0 46L-10 10L-46 0L-10 -10Z"
          opacity="0.9"></path>
        <circle r="60" fill="url(#nova-halo)"></circle>
      </g>
    </g>
    <!-- Faint atlas meridians -->
    <g
      fill="none"
      stroke="#ffffff"
      stroke-opacity="0.07"
      stroke-width="1.2"
    >
      <path d="M-100 780 Q720 520 1540 780"></path>
      <path d="M-100 840 Q720 600 1540 840"></path>
    </g>
    <defs>
      <radialGradient id="nova-halo">
        <stop offset="0%" stop-color="var(--brand-accent)" stop-opacity="0.35"
        ></stop>
        <stop offset="100%" stop-color="var(--brand-accent)" stop-opacity="0"
        ></stop>
      </radialGradient>
    </defs>
  </svg>

  <!-- Content -->
  <div
    class="container-site relative flex min-h-[92svh] flex-col justify-center pt-(--header-h) pb-28"
  >
    <div class="max-w-3xl">
      <p
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-[0.8rem] font-semibold tracking-[0.18em] text-accent-soft uppercase"
      >
        <Icon name="star4" class="h-3.5 w-3.5" />
        {site.location}
      </p>

      <h1
        class="font-display text-[clamp(2.25rem,6vw,4.5rem)] leading-[1.05] font-bold tracking-[-0.02em]"
      >
        {t.hero.h1}
      </h1>

      <p class="mt-6 max-w-2xl text-xl leading-relaxed font-medium text-white/90">
        {t.hero.sub}
      </p>

      <p class="mt-4 max-w-2xl leading-relaxed text-white/70">
        {t.hero.lead}
      </p>

      <div class="mt-10">
        <a
          href={waUrl(locale)}
          target="_blank"
          rel="noopener"
          class="inline-flex min-h-14 items-center gap-3 rounded-full bg-wa-strong px-8 py-4 text-lg font-semibold text-white shadow-[0_12px_32px_rgb(21_128_61/0.35)] transition-transform duration-200 hover:scale-[1.03] hover:bg-wa-deep active:scale-[0.99]"
        >
          <Icon name="whatsapp" class="h-6 w-6" />
          {t.hero.cta}
        </a>
      </div>
    </div>
  </div>

  <!-- Horizon arc into the next section -->
  <svg
    class="absolute right-0 bottom-0 left-0 h-[70px] w-full sm:h-[90px]"
    viewBox="0 0 1440 100"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      d="M0 100 L0 88 Q720 -20 1440 88 L1440 100 Z"
      fill="var(--surface)"></path>
    <path
      d="M0 88 Q720 -20 1440 88"
      fill="none"
      stroke="var(--brand-accent)"
      stroke-opacity="0.55"
      stroke-width="1.5"></path>
  </svg>
</section>

<style>
  .hero {
    background: linear-gradient(
      180deg,
      var(--brand-primary-deep) 0%,
      var(--brand-primary) 58%,
      #20305c 100%
    );
  }

  /* Gentle sky life: twinkling stars + a slowly breathing nova.
     The global prefers-reduced-motion rule in global.css disables these. */
  .twinkle-a {
    animation: twinkle 7s ease-in-out infinite alternate;
  }

  .twinkle-b {
    animation: twinkle 9s ease-in-out 2.5s infinite alternate-reverse;
  }

  @keyframes twinkle {
    from {
      opacity: 1;
    }
    to {
      opacity: 0.35;
    }
  }

  .nova-star {
    transform-box: fill-box;
    transform-origin: center;
    animation: nova-breathe 9s ease-in-out infinite;
  }

  @keyframes nova-breathe {
    0%,
    100% {
      transform: translateY(0) scale(1);
    }
    50% {
      transform: translateY(-9px) scale(1.06);
    }
  }

  /* The single brand gradient token, used as a soft atmospheric wash */
  .hero-glow {
    background:
      radial-gradient(
        640px 420px at 78% 16%,
        rgb(195 154 62 / 0.16),
        transparent 65%
      ),
      radial-gradient(
        900px 500px at 15% 110%,
        rgb(42 55 96 / 0.55),
        transparent 70%
      );
  }
</style>
