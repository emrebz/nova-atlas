---
import { site } from "../config/site";
import { useTranslations, asLocale, localeHome } from "../i18n/utils";
import Wordmark from "./Wordmark.astro";

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
const year = new Date().getFullYear();
const socialEntries = Object.entries(site.social);
---

<footer
  id="site-footer"
  class="border-t border-white/10 bg-primary-deep py-12 text-white/70"
  style="--wm-sub: var(--brand-accent-soft)"
>
  <div class="container-site">
    <div
      class="flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center"
    >
      <div class="text-white">
        <Wordmark suffix={t.brandSuffix} />
        <p class="mt-3 max-w-xs text-sm text-white/60">{t.footer.note}</p>
      </div>

      <nav aria-label={t.a11y.langNav}>
        <div class="flex items-center gap-1 text-sm font-semibold">
          <a
            href={localeHome("tr")}
            class="rounded-md px-2 py-2"
            class:list={[locale === "tr" ? "text-accent-soft" : "text-white/70 hover:text-white"]}
            aria-current={locale === "tr" ? "page" : undefined}>TR</a
          >
          <span aria-hidden="true" class="text-white/30">|</span>
          <a
            href={localeHome("en")}
            class="rounded-md px-2 py-2"
            class:list={[locale === "en" ? "text-accent-soft" : "text-white/70 hover:text-white"]}
            aria-current={locale === "en" ? "page" : undefined}>EN</a
          >
        </div>
      </nav>
    </div>

    {
      /*
        Social icons render only when site.social has entries (src/config/site.ts).
        Add e.g. { instagram: "https://instagram.com/novaatlas" } to enable.
      */
    }
    {
      socialEntries.length > 0 && (
        <ul class="mt-8 flex gap-4">
          {socialEntries.map(([name, url]) => (
            <li>
              <a
                href={url}
                target="_blank"
                rel="noopener"
                class="grid h-11 w-11 place-items-center rounded-full border border-white/15 text-sm font-semibold uppercase hover:border-accent-soft hover:text-accent-soft"
              >
                {name.slice(0, 2)}
              </a>
            </li>
          ))}
        </ul>
      )
    }

    {
      /*
        TÜRSAB: once the agency licence is granted, add the certificate badge
        here (trust signal competitors lead with), e.g.
        <div class="mt-8 flex items-center gap-3 text-sm">
          <img src="/tursab-badge.svg" alt="TÜRSAB" width="36" height="36" />
          TÜRSAB Belge No: XXXXX
        </div>
        (Matching placeholder lives in About.astro.)
      */
    }

    <p class="mt-10 border-t border-white/10 pt-6 text-sm text-white/50">
      © {year} {t.footer.line}. {t.footer.rights}
    </p>
  </div>
</footer>
