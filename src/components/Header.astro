---
import { useTranslations, asLocale, altLocale, localeHome } from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import Wordmark from "./Wordmark.astro";

interface Props {
  /** Reciprocal locale paths for the current page (language switch). */
  alternates?: { tr: string; en: string };
}

const { alternates = { tr: "/", en: "/en/" } } = Astro.props;

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
const other = altLocale(locale);

// Prefix section anchors with the home path so the nav works from every page
// (e.g. tour detail pages), not just the homepage.
const home = localeHome(locale);
const vipPath = locale === "tr" ? "/vip-tasimacilik/" : "/en/vip-transfer/";
const navItems = [
  { label: t.nav.home.label, href: `${home}#${t.nav.home.anchor}` },
  { label: t.nav.about.label, href: `${home}#${t.nav.about.anchor}` },
  { label: t.nav.routes.label, href: `${home}#${t.nav.routes.anchor}` },
  { label: t.nav.services.label, href: `${home}#${t.nav.services.anchor}` },
  {
    label: t.nav.vip.label,
    href: vipPath,
    current: Astro.url.pathname === vipPath,
  },
  { label: t.nav.contact.label, href: `${home}#${t.nav.contact.anchor}` },
];
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div
    class="container-site flex h-(--header-h) items-center justify-between gap-6"
  >
    <a
      href={localeHome(locale)}
      class="rounded-md"
      aria-label={`NovaAtlas ${t.brandSuffix}`}
    >
      <Wordmark suffix={t.brandSuffix} />
    </a>

    <nav aria-label={t.a11y.mainNav} class="hidden xl:block">
      <ul class="flex items-center gap-6 xl:gap-7">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="nav-link relative py-2 text-[0.95rem] font-medium"
                aria-current={item.current ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-1">
      <ThemeToggle
        toDarkLabel={t.a11y.themeToDark}
        toLightLabel={t.a11y.themeToLight}
      />

      <nav aria-label={t.a11y.langNav} class="hidden md:block">
        <div class="flex items-center gap-1 text-sm font-semibold">
          <a
            href={alternates.tr}
            class="lang-link rounded-md px-2 py-2"
            aria-current={locale === "tr" ? "page" : undefined}>TR</a
          >
          <span aria-hidden="true" class="opacity-40">|</span>
          <a
            href={alternates.en}
            class="lang-link rounded-md px-2 py-2"
            aria-current={locale === "en" ? "page" : undefined}>EN</a
          >
        </div>
      </nav>

      <button
        id="menu-open"
        type="button"
        class="grid h-11 w-11 place-items-center rounded-lg xl:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t.a11y.menuOpen}
      >
        <svg
          viewBox="0 0 24 24"
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h10"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile full-screen menu -->
  <div
    id="mobile-menu"
    hidden
    role="dialog"
    aria-modal="true"
    aria-label={t.a11y.mainNav}
    class="fixed inset-0 z-50 flex flex-col bg-primary-deep text-white xl:hidden"
  >
    <div
      class="container-site flex h-(--header-h) w-full shrink-0 items-center justify-between"
    >
      <span style="--wm-sub: var(--brand-accent-soft)">
        <Wordmark suffix={t.brandSuffix} />
      </span>
      <div class="flex items-center gap-1">
        <ThemeToggle
          toDarkLabel={t.a11y.themeToDark}
          toLightLabel={t.a11y.themeToLight}
        />
        <button
          id="menu-close"
          type="button"
          class="grid h-11 w-11 place-items-center rounded-lg"
          aria-label={t.a11y.menuClose}
        >
          <svg
            viewBox="0 0 24 24"
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M6 6l12 12M18 6L6 18"></path>
          </svg>
        </button>
      </div>
    </div>

    <nav
      aria-label={t.a11y.mainNav}
      class="container-site flex w-full flex-1 flex-col justify-center pb-16"
    >
      <ul class="space-y-2">
        {
          navItems.map((item, i) => (
            <li>
              <a
                href={item.href}
                class="mobile-nav-link font-display block rounded-lg py-3 text-3xl font-semibold tracking-tight hover:text-accent-soft"
                aria-current={item.current ? "page" : undefined}
              >
                <span class="mr-3 text-sm font-normal text-accent-soft tabular-nums">
                  0{i + 1}
                </span>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div
        class="mt-10 flex items-center gap-2 border-t border-white/15 pt-8 text-lg font-semibold"
        aria-label={t.a11y.langNav}
      >
        <a
          href={alternates.tr}
          class="rounded-md px-3 py-2"
          class:list={[locale === "tr" ? "text-accent-soft underline underline-offset-8" : "text-white/80"]}
          aria-current={locale === "tr" ? "page" : undefined}>TR</a
        >
        <span aria-hidden="true" class="text-white/30">|</span>
        <a
          href={alternates.en}
          class="rounded-md px-3 py-2"
          class:list={[locale === "en" ? "text-accent-soft underline underline-offset-8" : "text-white/80"]}
          aria-current={locale === "en" ? "page" : undefined}>EN</a
        >
      </div>
    </nav>
  </div>
</header>

<style>
  /* Transparent over the dark hero → white text + soft gold subtitle */
  #site-header {
    color: #fff;
    --wm-sub: var(--brand-accent-soft);
    transition: color 0.25s ease;
  }

  /* Scrolled bar background lives on a pseudo-element: backdrop-filter on the
     header itself would turn it into the containing block for the fixed
     mobile menu, clipping the menu (and its background) to the 72px bar. */
  #site-header::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0;
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    box-shadow:
      0 1px 0 rgb(11 18 38 / 0.05),
      0 10px 30px rgb(11 18 38 / 0.08);
    transition: opacity 0.25s ease;
  }

  /* Scrolled: translucent light bar → ink text */
  #site-header[data-scrolled] {
    color: var(--ink);
    --wm-sub: var(--brand-accent-strong);
  }

  #site-header[data-scrolled]::before {
    opacity: 1;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 2px;
    border-radius: 2px;
    background: var(--brand-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link[aria-current="page"]::after {
    transform: scaleX(1);
  }

  .mobile-nav-link[aria-current="page"] {
    color: var(--brand-accent-soft);
  }

  .lang-link[aria-current="page"] {
    color: var(--brand-accent-soft);
  }
  #site-header[data-scrolled] .lang-link[aria-current="page"] {
    color: var(--brand-accent-strong);
  }

  @keyframes menu-in {
    from {
      opacity: 0;
    }
  }
  #mobile-menu:not([hidden]) {
    animation: menu-in 0.2s ease;
  }
</style>

<script>
  const header = document.getElementById("site-header")!;
  const openBtn = document.getElementById("menu-open")!;
  const closeBtn = document.getElementById("menu-close")!;
  const menu = document.getElementById("mobile-menu")!;

  // Translucent bar once the user leaves the hero's top edge.
  // An IO sentinel is cheaper and more reliable than scroll events.
  const setScrolled = () =>
    header.toggleAttribute("data-scrolled", window.scrollY > 12);
  setScrolled();
  if ("IntersectionObserver" in window) {
    const sentinel = document.createElement("div");
    sentinel.style.cssText =
      "position:absolute;top:0;left:0;width:1px;height:24px;pointer-events:none;visibility:hidden;";
    document.body.prepend(sentinel);
    new IntersectionObserver(([entry]) =>
      header.toggleAttribute("data-scrolled", !entry.isIntersecting)
    ).observe(sentinel);
  } else {
    window.addEventListener("scroll", setScrolled, { passive: true });
  }

  // Mobile menu: toggle + focus trap + Esc + close-on-link-tap
  let lastFocused: Element | null = null;

  function openMenu() {
    lastFocused = document.activeElement;
    menu.hidden = false;
    document.body.style.overflow = "hidden";
    openBtn.setAttribute("aria-expanded", "true");
    closeBtn.focus();
  }

  function closeMenu() {
    menu.hidden = true;
    document.body.style.overflow = "";
    openBtn.setAttribute("aria-expanded", "false");
    if (lastFocused instanceof HTMLElement) lastFocused.focus();
  }

  openBtn.addEventListener("click", openMenu);
  closeBtn.addEventListener("click", closeMenu);

  menu.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("a")) closeMenu();
  });

  menu.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeMenu();
      return;
    }
    if (e.key !== "Tab") return;
    const focusables = menu.querySelectorAll<HTMLElement>(
      'a[href], button:not([disabled])'
    );
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
