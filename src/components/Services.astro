---
import { waUrl } from "../config/site";
import { useTranslations, asLocale } from "../i18n/utils";
import Icon from "./Icon.astro";
import Reveal from "./Reveal.astro";

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

<section id={t.nav.services.anchor} class="bg-surface-2 py-16 md:py-28 lg:py-32">
  <div class="container-site">
    <Reveal class="mx-auto max-w-2xl text-center">
      <h2
        class="font-display text-[clamp(1.9rem,4vw,2.75rem)] leading-tight font-bold tracking-tight text-primary"
      >
        {t.services.h2}
      </h2>
      <div class="mt-6 space-y-4 text-muted">
        {t.services.paragraphs.map((p) => <p>{p}</p>)}
      </div>
    </Reveal>

    <ul class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6">
      {
        t.services.items.map((item, i) => (
          <Reveal
            as="li"
            delay={i * 90}
            class="relative flex h-full flex-col rounded-2xl border border-line bg-surface p-6 pt-7 transition duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgb(11_18_38/0.09)]"
          >
            <span class="badge-soon absolute -top-3 right-5 rounded-full px-3 py-1 text-xs font-semibold tracking-wide text-white">
              {t.services.badge}
            </span>
            <span class="grid h-13 w-13 place-items-center rounded-xl bg-primary text-accent-soft">
              <Icon name={item.icon} class="h-7 w-7" />
            </span>
            <h3 class="font-display mt-5 text-lg font-semibold tracking-tight text-ink">
              {item.title}
            </h3>
          </Reveal>
        ))
      }
    </ul>

    <Reveal class="mt-12 text-center">
      <a
        href={waUrl(locale)}
        target="_blank"
        rel="noopener"
        class="inline-flex min-h-12 items-center gap-2.5 rounded-full bg-wa-strong px-7 py-3.5 font-semibold text-white shadow-[0_10px_28px_rgb(21_128_61/0.3)] transition-transform duration-200 hover:scale-[1.03] hover:bg-wa-deep active:scale-[0.99]"
      >
        <Icon name="whatsapp" class="h-5 w-5" />
        {t.services.cta}
      </a>
    </Reveal>
  </div>
</section>
