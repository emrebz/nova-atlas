---
import { Image } from "astro:assets";
import { site } from "../config/site";
import { useTranslations, asLocale } from "../i18n/utils";
import Icon from "./Icon.astro";
import Reveal from "./Reveal.astro";
import logo from "../../docs/logo/nova-atlas-no-bg.png";
import darkLogo from "../../docs/logo/nova-atlas-dark-mode.png";
import tursabLogo from "../../docs/logo/tursab.png";

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);
---

<section id={t.nav.about.anchor} class="bg-surface py-16 md:py-28 lg:py-32">
  <div class="container-site">
    <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:gap-16">
      <Reveal>
        <h2
          class="font-display text-[clamp(1.9rem,4vw,2.75rem)] leading-tight font-bold tracking-tight text-heading"
        >
          {t.about.h2}
        </h2>
        <div class="mt-6 space-y-5 text-muted">
          {t.about.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </Reveal>

      <Reveal delay={120}>
        <figure
          class="about-brand-panel rounded-3xl border p-2"
        >
          <div
            class="about-brand-media relative aspect-video overflow-hidden rounded-[1.35rem]"
            role="img"
            aria-label={t.about.logoAlt}
            data-about-logo-media
          >
            <Image
              src={logo}
              alt=""
              width={640}
              densities={[1, 2]}
              loading="lazy"
              class="theme-logo-light absolute inset-0 h-full w-full object-contain p-6 sm:p-8"
            />
            <Image
              src={darkLogo}
              alt=""
              widths={[480, 720, 960]}
              sizes="(min-width: 1024px) 36vw, (min-width: 640px) 32rem, calc(100vw - 6rem)"
              loading="lazy"
              class="theme-logo-dark absolute inset-0 h-full w-full object-cover"
            />
            <video
              class="about-logo-video pointer-events-none absolute inset-0 h-full w-full object-cover"
              data-about-logo-video
              data-light-src={site.logoAnimation.lightMp4}
              data-dark-src={site.logoAnimation.darkMp4}
              autoplay
              muted
              loop
              playsinline
              webkit-playsinline
              preload="none"
              disablepictureinpicture
              tabindex="-1"
              aria-hidden="true"
            ></video>
          </div>
          <figcaption class="mt-4 flex items-center justify-center gap-2 px-4 pb-3 text-sm font-medium text-muted">
            <Image
              src={tursabLogo}
              alt=""
              width={128}
              densities={[1, 2]}
              loading="lazy"
              class="h-24 w-24 shrink-0 object-contain"
            />
            {t.about.tursab}
          </figcaption>
        </figure>
      </Reveal>
    </div>

    <div class="mt-16 md:mt-24">
      <Reveal>
        <h3
          class="font-display text-2xl font-semibold tracking-tight text-heading md:text-3xl"
        >
          {t.about.whyTitle}
        </h3>
      </Reveal>
      <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:gap-6">
        {
          t.about.why.map((item, i) => (
            <Reveal
              as="li"
              delay={i * 90}
              class="group flex h-full items-center gap-5 rounded-2xl border border-line bg-surface p-6 transition duration-300 hover:-translate-y-1 hover:shadow-[0_16px_40px_rgb(11_18_38/0.09)]"
            >
              <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-primary text-accent-soft transition-colors duration-300 group-hover:bg-primary-soft">
                <Icon name={item.icon} class="h-6 w-6" />
              </span>
              <span class="font-medium text-ink">{item.text}</span>
            </Reveal>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .about-brand-panel {
    background: linear-gradient(158deg, #ffffff 0%, #f4f0e8 100%);
    border-color: rgb(195 154 62 / 0.3);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.85),
      0 18px 48px -16px rgb(11 18 38 / 0.18);
  }

  .theme-logo-dark {
    display: none;
  }

  .about-logo-video {
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .about-logo-video.is-playing {
    opacity: 1;
  }

  :global(html[data-theme="dark"]) .theme-logo-light {
    display: none;
  }

  :global(html[data-theme="dark"]) .theme-logo-dark {
    display: block;
  }

  :global(html[data-theme="dark"]) .about-brand-panel {
    background: linear-gradient(145deg, #111c36 0%, #070d1a 100%);
    border-color: rgb(227 200 138 / 0.38);
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 0.07),
      inset 0 0 0 1px rgb(195 154 62 / 0.07),
      0 24px 60px -22px rgb(0 0 0 / 0.7),
      0 0 42px rgb(195 154 62 / 0.07);
  }

  @media (prefers-reduced-motion: reduce) {
    .about-logo-video {
      display: none;
    }
  }
</style>

<script>
  const aboutLogoMedia = document.querySelector<HTMLElement>(
    "[data-about-logo-media]"
  );
  const aboutLogoVideo = aboutLogoMedia?.querySelector<HTMLVideoElement>(
    "[data-about-logo-video]"
  );

  if (aboutLogoMedia && aboutLogoVideo) {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    let isVisible = false;
    let activeSource = "";

    aboutLogoVideo.defaultMuted = true;
    aboutLogoVideo.muted = true;
    aboutLogoVideo.volume = 0;

    const attemptPlayback = () => {
      if (reduceMotion || !isVisible || document.hidden) return;
      aboutLogoVideo.muted = true;
      aboutLogoVideo.play().catch(() => {
        // This is a decorative, non-interactive film. If a browser blocks
        // autoplay, the theme-matched static logo remains visible underneath.
      });
    };

    const syncThemeSource = () => {
      const dark = document.documentElement.dataset.theme === "dark";
      const nextSource = dark
        ? aboutLogoVideo.dataset.darkSrc
        : aboutLogoVideo.dataset.lightSrc;
      if (!nextSource || nextSource === activeSource) {
        attemptPlayback();
        return;
      }

      activeSource = nextSource;
      aboutLogoVideo.pause();
      aboutLogoVideo.classList.remove("is-playing");
      aboutLogoVideo.src = nextSource;
      aboutLogoVideo.load();
      attemptPlayback();
    };

    aboutLogoVideo.addEventListener("playing", () => {
      aboutLogoVideo.classList.add("is-playing");
    });
    aboutLogoVideo.addEventListener("loadeddata", attemptPlayback);
    aboutLogoVideo.addEventListener("canplay", attemptPlayback);

    new MutationObserver(syncThemeSource).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    if ("IntersectionObserver" in window) {
      new IntersectionObserver(
        ([entry]) => {
          isVisible = entry.isIntersecting;
          if (isVisible) {
            syncThemeSource();
          } else {
            aboutLogoVideo.pause();
          }
        },
        { threshold: 0.15 }
      ).observe(aboutLogoMedia);
    } else {
      isVisible = true;
      syncThemeSource();
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) aboutLogoVideo.pause();
      else attemptPlayback();
    });

    syncThemeSource();
  }
</script>
