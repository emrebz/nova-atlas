---
import "../styles/global.css";
import { site, waUrl } from "../config/site";
import { useTranslations, asLocale, localeHome, altLocale } from "../i18n/utils";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

// Above-the-fold font weights, preloaded to avoid layout shift on swap.
// latin-ext carries the Turkish diacritics (ç ğ ş ı İ ö ü) used in the H1.
import bricolage700 from "@fontsource/bricolage-grotesque/files/bricolage-grotesque-latin-700-normal.woff2?url";
import bricolage700Ext from "@fontsource/bricolage-grotesque/files/bricolage-grotesque-latin-ext-700-normal.woff2?url";
import inter400 from "@fontsource/inter/files/inter-latin-400-normal.woff2?url";
import inter400Ext from "@fontsource/inter/files/inter-latin-ext-400-normal.woff2?url";

interface Props {
  /** Overrides <title>; defaults to the locale's homepage title. */
  title?: string;
  /** Overrides <meta description>; defaults to the locale's homepage description. */
  description?: string;
  /** Reciprocal locale paths for this page (hreflang + language switch). */
  alternates?: { tr: string; en: string };
  /** Extra JSON-LD objects to append (e.g. BreadcrumbList, TouristTrip). */
  extraSchema?: Record<string, unknown>[];
}

const {
  title: pageTitle,
  description: pageDescription,
  alternates = { tr: "/", en: "/en/" },
  extraSchema = [],
} = Astro.props;

const locale = asLocale(Astro.currentLocale);
const t = useTranslations(locale);

const title = pageTitle ?? t.meta.title;
const description = pageDescription ?? t.meta.description;

const canonical = new URL(Astro.url.pathname, site.url).href;
const trUrl = new URL(alternates.tr, site.url).href;
const enUrl = new URL(alternates.en, site.url).href;
const ogImage = new URL("/og-image.jpg", site.url).href;

const travelAgency = {
  "@context": "https://schema.org",
  "@type": "TravelAgency",
  "@id": `${site.url}/#organization`,
  name: site.brand,
  alternateName: site.alternateNames,
  url: `${site.url}/`,
  description: t.meta.description,
  telephone: `+${site.phoneRaw}`,
  email: site.email,
  image: ogImage,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Çorlu",
    addressRegion: "Tekirdağ",
    addressCountry: "TR",
  },
  openingHours: site.openingHours,
  sameAs: Object.values(site.social),
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${site.url}/#website`,
  name: site.brand,
  alternateName: site.alternateNames,
  url: `${site.url}/`,
  inLanguage: ["tr", "en"],
  publisher: { "@id": `${site.url}/#organization` },
};

const structuredData = [
  travelAgency,
  ...(Astro.url.pathname === "/" ? [website] : []),
  ...extraSchema,
];

const preloadFonts = [bricolage700, bricolage700Ext, inter400, inter400Ext];
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (() => {
        const storageKey = "nova-atlas-theme";
        const root = document.documentElement;
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)");

        const storedTheme = () => {
          try {
            const value = localStorage.getItem(storageKey);
            return value === "light" || value === "dark" ? value : null;
          } catch {
            return null;
          }
        };

        const syncControls = (theme) => {
          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            const nextTheme = theme === "dark" ? "light" : "dark";
            const label =
              nextTheme === "dark"
                ? button.dataset.labelDark
                : button.dataset.labelLight;

            button.setAttribute("aria-pressed", String(theme === "dark"));
            if (label) {
              button.setAttribute("aria-label", label);
              button.setAttribute("title", label);
            }
          });
        };

        const applyTheme = (theme, source) => {
          root.dataset.theme = theme;
          root.dataset.themeSource = source;
          root.style.colorScheme = theme;
          syncControls(theme);
        };

        const saved = storedTheme();
        applyTheme(saved ?? (systemTheme.matches ? "dark" : "light"), saved ? "user" : "system");

        systemTheme.addEventListener("change", (event) => {
          if (!storedTheme()) applyTheme(event.matches ? "dark" : "light", "system");
        });

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;
          const button = target.closest("[data-theme-toggle]");
          if (!button) return;

          const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
          try {
            localStorage.setItem(storageKey, nextTheme);
          } catch {
            // Theme still changes for this page when storage is unavailable.
          }
          applyTheme(nextTheme, "user");
        });

        document.addEventListener("DOMContentLoaded", () => {
          syncControls(root.dataset.theme ?? "light");
        });
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0b1226" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- hreflang alternates (reciprocal on every page) -->
    <link rel="alternate" hreflang="tr" href={trUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={trUrl} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={t.meta.ogLocale} />
    <meta
      property="og:locale:alternate"
      content={locale === "tr" ? "en_US" : "tr_TR"}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      preloadFonts.map((href) => (
        <link
          rel="preload"
          href={href}
          as="font"
          type="font/woff2"
          crossorigin
        />
      ))
    }

    {
      structuredData.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }

    <!-- Flags JS availability so scroll-reveal styles never hide content without it -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>

  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-lg focus:bg-primary focus:px-5 focus:py-3 focus:font-semibold focus:text-white"
    >
      {t.a11y.skip}
    </a>

    <Header alternates={alternates} />

    <main id="main">
      <slot />
    </main>

    <Footer />
    <WhatsAppFab />
  </body>
</html>
